  "keyFeatures": [
    "Complete mail server stack deployable with Docker Compose",
    "Web UI for administration (domains, mailboxes, aliases, DKIM, etc.)",
    "Built-in antispam with Rspamd and antivirus with ClamAV",
    "Automatic Let's Encrypt SSL/TLS certificate management via ACME",
    "SOGo groupware with webmail, CalDAV, CardDAV, and ActiveSync",
    "REST API with read-only and read-write key support",
    "OAuth2/SSO integration (Keycloak, LDAP)",
    "Full-text search (FTS) with Dovecot Flatcurve/Xapian",
    "Watchdog service for automatic container health monitoring and restart",
    "High availability and replication support"
  ],
  "publicApiSurface": [
